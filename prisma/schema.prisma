// prisma/schema.prisma

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum Role {
    CUSTOMER
    ADMIN
}

model User {
    id            String    @id @default(uuid()) @db.Uuid
    name          String?
    phone_number  String?
    password      String?
    email         String    @unique
    emailVerified DateTime?
    image         String?
    role          Role      @default(CUSTOMER)

    accounts Account[]
    sessions Session[]
    bookings Booking[]
    reviews  Review[]

    // บูธที่ User คนนี้ (Admin) เป็นคนสร้างหรือดูแล
    booths Booth[]
}

model Account {
    id                String  @id @default(uuid()) @db.Uuid
    userId            String  @db.Uuid
    type              String
    provider          String
    providerAccountId String
    refresh_token     String? @db.Text
    access_token      String? @db.Text
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String? @db.Text
    session_state     String?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(uuid()) @db.Uuid
    sessionToken String   @unique
    userId       String   @db.Uuid
    expires      DateTime

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
    identifier String
    token      String
    expires    DateTime

    @@unique([identifier, token])
}

model Booth {
    id           String  @id @default(uuid()) @db.Uuid
    name         String
    price        Float
    is_available Boolean @default(true) // เปิด/ปิด ให้เช่า
    dimension    String

    // พิกัดสำหรับแสดงบนแผนที่ตลาด 2D
    latitude  Decimal? @db.Decimal(10, 8)
    longitude Decimal? @db.Decimal(11, 8)

    // ข้อมูลสำหรับ 3D Visualization
    position_x Float?  @default(0)
    position_y Float?  @default(0)
    position_z Float?  @default(0)
    rotation_x Float?  @default(0)
    rotation_y Float?  @default(0)
    rotation_z Float?  @default(0)
    scale      Float?  @default(1)
    model_url  String? // URL สำหรับไฟล์ (.glb, .gltf)

    images      Image[]
    bookings    Booking[]
    reviews     Review[]
    booth_items BoothItem[]

    // โซนของบูธ (เช่น โซนอาหาร, โซนแฟชั่น)
    zone_id String? @db.Uuid
    zone    Zone?   @relation(fields: [zone_id], references: [id], onDelete: SetNull)

    // ผูกกับ User (Admin) คนที่สร้าง
    user_id String? @db.Uuid
    user    User?   @relation(fields: [user_id], references: [id], onDelete: SetNull)

    created_at DateTime @default(now())
    updated_at DateTime @updatedAt
}

model BoothItem {
    id       String @id @default(uuid()) @db.Uuid
    booth_id String @db.Uuid
    booth    Booth  @relation(fields: [booth_id], references: [id], onDelete: Cascade)

    item_type  String // "table" | "chair" | "rack" | "shelf" | "counter"
    color      String? // hex color override

    // ตำแหน่งและการหมุนของชิ้นนี้ภายในบูธ (Local Space)
    position_x Float @default(0)
    position_y Float @default(0)
    position_z Float @default(0)

    rotation_x Float @default(0)
    rotation_y Float @default(0)
    rotation_z Float @default(0)

    created_at DateTime @default(now())
    updated_at DateTime @updatedAt
}

model Zone {
    id          String  @id @default(uuid()) @db.Uuid
    name        String
    description String?
    color_code  String? // สำหรับแยกสีตามโซนในแผนที่

    booths Booth[]

    created_at DateTime @default(now())
    updated_at DateTime @updatedAt
}

model Image {
    id       String @id @default(uuid()) @db.Uuid
    path     String
    booth_id String @db.Uuid
    booth    Booth  @relation(fields: [booth_id], references: [id], onDelete: Cascade)
}

enum PaymentStatus {
    PENDING
    SUCCESS
    CANCEL
}

enum BookingStatus {
    PENDING
    CONFIRMED
    COMPLETED
    CANCELLED
}

model Booking {
    id               String        @id @default(uuid()) @db.Uuid
    start_date       DateTime
    end_date         DateTime
    total_price      Float
    payment_status   PaymentStatus @default(PENDING)
    booking_status   BookingStatus @default(PENDING)
    payment_slip_url String?

    user_id String @db.Uuid
    user    User   @relation(fields: [user_id], references: [id])

    booth_id String @db.Uuid
    booth    Booth  @relation(fields: [booth_id], references: [id])

    created_at DateTime @default(now())
}

enum ReviewType {
    BOOTH // รีวิวเฉพาะบูธ
    MARKET // รีวิวภาพรวมตลาด
}

model Review {
    id         String     @id @default(uuid()) @db.Uuid
    rating     Decimal    @db.Decimal(2, 1)
    comment    String?
    type       ReviewType @default(BOOTH)
    created_at DateTime   @default(now())

    user_id String @db.Uuid
    user    User   @relation(fields: [user_id], references: [id])

    // อ้างอิง Booth (Optional เพื่อให้ Customer ทั่วไปรีวิวภาพรวมตลาดได้)
    booth_id String? @db.Uuid
    booth    Booth?  @relation(fields: [booth_id], references: [id])
}
